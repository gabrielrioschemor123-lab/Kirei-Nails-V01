rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Standalone validation helper for appointments
    function isValidAppointment(data) {
      return data.id is string && data.id.size() <= 128
          && data.clientName is string && data.clientName.size() <= 128
          && data.phone is string && data.phone.size() <= 64
          && data.serviceId is string && data.serviceId.size() <= 128
          && data.serviceName is string && data.serviceName.size() <= 128
          && data.zone is string && data.zone.size() <= 256
          && data.date is string && data.date.size() <= 32
          && data.time is string && data.time.size() <= 16
          && data.createdAt is string && data.createdAt.size() <= 64;
    }
    
    // Appointments rules
    match /appointments/{appointmentId} {
      allow read: if true;
      allow create: if isValidAppointment(request.resource.data);
      allow delete: if true;
    }
  }
}
